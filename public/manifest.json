{
  "manifest_version": 3,
  "name": "YouTube Comment Search",
  "version": "2.0.0",
  "description": "Search YouTube comments in real time — highlight, filter, and jump to matching comments instantly.",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "YouTube Comment Search"
  },

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content/index.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "activeTab",
    "identity",
    "storage"
  ],

  "oauth2": {
    "client_id": "432892486848-bemngrqcm4ksjjop6lr8vorbgcfhjurf.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/youtube.force-ssl"]
  },

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.googleapis.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["popup/*.js", "popup/*.css", "assets/*"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]

}
